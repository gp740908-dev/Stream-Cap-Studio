# ─── StreamCap Studio — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=streamcap
POSTGRES_USER=streamcap
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://streamcap:change_me_strong_password@db:5432/streamcap

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379/0

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:change_me_redis_password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:change_me_redis_password@redis:6379/1

# ─── FastAPI Auth (JWT) ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Admin Credentials (single user) ─────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin_password

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# Get token from @BotFather, chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Storage ──────────────────────────────────────────────────────────────────
OUTPUT_DIR=/app/outputs
UPLOAD_DIR=/app/uploads
TMP_DIR=/tmp/streamcap

# ─── Optional MinIO (S3-compatible backup) ────────────────────────────────────
MINIO_ENABLED=false
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=streamcap-outputs
MINIO_SECURE=false

# ─── Chrome / Playwright ──────────────────────────────────────────────────────
CHROME_VIEWPORT_WIDTH=1920
CHROME_VIEWPORT_HEIGHT=1080
CHROME_PRE_RECORD_DELAY=5        # seconds to wait before starting FFmpeg capture
CHROME_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36

# ─── FFmpeg Defaults ──────────────────────────────────────────────────────────
DEFAULT_RESOLUTION=1080p
DEFAULT_FPS=30
DEFAULT_VIDEO_BITRATE_1080P=8000k
DEFAULT_VIDEO_BITRATE_720P=5000k
DEFAULT_AUDIO_BITRATE=320k
DEFAULT_AUDIO_SAMPLE_RATE=48000

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
NEXTAUTH_URL=http://localhost
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_generate_with_openssl_rand_base64_32

# ─── Nginx / Domain ───────────────────────────────────────────────────────────
DOMAIN=localhost
